{
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  },
  "AllowedHosts": "*",
  "Urls": "http://+:8080",
  "ReverseProxy": {
    "Routes": {
      "auth-route":        { "ClusterId": "auth-cluster",    "Match": { "Path": "/api/auth/{**catch-all}" } },
      "players-route":     { "ClusterId": "profile-cluster", "Match": { "Path": "/api/players/{**catch-all}" } },
      "staff-route":       { "ClusterId": "profile-cluster", "Match": { "Path": "/api/staff/{**catch-all}" } },
      "marketplace-route": { "ClusterId": "profile-cluster", "Match": { "Path": "/api/marketplace/{**catch-all}" } },
      "teams-route":       { "ClusterId": "team-cluster",    "Match": { "Path": "/api/teams/{**catch-all}" } },
      "stadiums-route":    { "ClusterId": "stadium-cluster", "Match": { "Path": "/api/stadiums/{**catch-all}" } },
      "matches-route":     { "ClusterId": "match-cluster",   "Match": { "Path": "/api/matches/{**catch-all}" } }
    },
    "Clusters": {
      "auth-cluster":    { "Destinations": { "auth":    { "Address": "http://auth:8080"    } } },
      "profile-cluster": { "Destinations": { "profile": { "Address": "http://profile:8080" } } },
      "team-cluster":    { "Destinations": { "team":    { "Address": "http://team:8080"    } } },
      "stadium-cluster": { "Destinations": { "stadium": { "Address": "http://stadium:8080" } } },
      "match-cluster":   { "Destinations": { "match":   { "Address": "http://match:8080"   } } }
    }
  }
}
