# Copy this file to .env and fill in the values before running docker-compose.
# Never commit .env to git.

# JWT signing key — minimum 32 characters, use a random string
# ASP.NET Core reads environment variables using __ as the section separator,
# so Jwt__Key overrides the "Key" property inside the "Jwt" section.
Jwt__Key=your-super-secret-jwt-key-minimum-32-chars

# SQL Server connection string (overrides appsettings.json)
ConnectionStrings__futsalConn=Server=localhost;Database=FutsalDatabase;Trusted_Connection=True;TrustServerCertificate=True

# SQL Server SA password (used by docker-compose only)
SA_PASSWORD=CoreFutsal_Dev@2024
